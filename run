#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

CMD="${1:-help}"
shift || true

case "$CMD" in
    server)
        exec python -m arbiter.server "$@"
        ;;
    test)
        exec python -m pytest tests/ "$@"
        ;;
    test-all)
        exec python -m pytest tests/ -m "not calibration" "$@"
        ;;
    calibrate)
        exec python -m arbiter.calibrate "$@"
        ;;
    ps)
        exec python -m arbiter.cli ps "$@"
        ;;
    jobs)
        exec python -m arbiter.cli jobs "$@"
        ;;
    submit)
        exec python -m arbiter.cli submit "$@"
        ;;
    cancel)
        exec python -m arbiter.cli cancel "$@"
        ;;
    health)
        exec python -m arbiter.cli health "$@"
        ;;
    help|--help|-h)
        cat <<'HELP'
Arbiter - Unified GPU Model Serving Platform

Usage: ./run <command> [args...]

Commands:
  server              Start the Arbiter API server
  test                Run fast tests (unit + integration, no calibration)
  test-all            Run all tests except calibration
  calibrate <model>   Run calibration for a model (or --all for all models)
  ps                  Show loaded models and VRAM usage
  jobs                List job queue
  submit <type> ...   Submit an inference job
  cancel <job_id>     Cancel a job
  health              Check server health
  help                Show this help
HELP
        ;;
    *)
        echo "Unknown command: $CMD (try: ./run help)" >&2
        exit 1
        ;;
esac
